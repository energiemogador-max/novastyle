# Netlify _headers — long cache for all versioned static assets
# GitHub Pages ignores this; if hosted on Netlify it unlocks massive repeat-visit speed

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/images/*
  Cache-Control: public, max-age=31536000, immutable

/logo.png
  Cache-Control: public, max-age=31536000, immutable

/*.html
  Cache-Control: public, max-age=600, must-revalidate

/
  Cache-Control: public, max-age=600, must-revalidate
