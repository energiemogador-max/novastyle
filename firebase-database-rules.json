{
  "rules": {
    ".read": false,
    ".write": false,
    "reviews": {
      ".read": true,
      ".write": "auth != null",
      "$productId": {
        ".read": true,
        ".write": "auth != null",
        "$reviewId": {
          ".read": true,
          ".write": "auth != null",
          ".validate": "newData.hasChildren(['name','rating','text','date'])"
        }
      }
    },
    "pending_reviews": {
      ".read": false,
      ".write": true
    },
    "online_visitors": {
      ".read": true,
      ".write": true
    },
    "products": {
      ".read": true,
      ".write": "auth != null"
    },
    "orders": {
      ".read": false,
      ".write": true
    }
  }
}
